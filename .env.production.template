# ==============================================================================
# Hotel-ECS Gateway Production Environment Configuration Template
# คัดลอกไฟล์นี้ไปวางที่ /opt/hotel-ecs/config/.env แล้วแก้ไขข้อมูลให้ตรงกับหน้างาน
# ==============================================================================

# พอร์ตบริการหลังบ้าน
PORT=3000
NODE_ENV=production

# 🔌 การเชื่อมต่อตู้สาขา Phonik PBX จริงผ่านโครงข่าย LAN (TCP/IP)
PBX_MODE=tcp
PBX_HOST=192.168.1.91        # IP จริงของตู้ PBX
PBX_PORT=23                  # พอร์ต TCP ของตู้สาขา (Telnet)

# 💾 ตำแหน่งของฐานข้อมูล SQLite ใน Container
# โฟลเดอร์จะถูก Mount ไปยัง /opt/hotel-ecs/data/ บน Host OS อัตโนมัติ
DATABASE_PATH=/app/backend/hotel.db

# 🛡️ โทเคนสำหรับเชื่อมต่อ Cloudflare Tunnel (โดเมน hotel.nithep.com)
CLOUDFLARE_TUNNEL_TOKEN=your_secure_cloudflare_tunnel_token_here

# 🛎️ การตั้งค่าระบบความปลอดภัยและการแจ้งเตือนผ่าน Google Chat
# ตัวอย่าง: https://chat.googleapis.com/v1/spaces/XXXX/messages?key=YYYY&token=ZZZZ
GOOGLE_CHAT_WEBHOOK_URL=your_google_chat_webhook_url_here

# 🤖 โทเคนสำหรับแจ้งเตือนและระบบควบคุมผ่านบอท Telegram (ถ้ามี)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
